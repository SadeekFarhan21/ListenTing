---
import AppShell from "../../layouts/AppShell.astro";
import type { Chapter } from "../../lib/chapter";
import { readFileSync } from "node:fs";
import { resolve } from "node:path";

const chapterJson = readFileSync(
  resolve(process.cwd(), "public/audiobook/ch1.json"),
  "utf8",
);
const chapter: Chapter & { stub?: boolean } = JSON.parse(chapterJson);
const isStub = (chapter as any).stub === true;
---

<AppShell title="Listen · 始计第一" active="listen">
  <span slot="title">{chapter.title}</span>
  <div slot="actions">
    <button class="btn btn-ghost" id="toggle-pinyin" type="button" aria-pressed="true">
      Pinyin: on
    </button>
  </div>

  {isStub && (
    <div class="stub-banner">
      Showing stub data with placeholder timings. Run <code>pnpm prepare:chapter</code> with
      <code>ANTHROPIC_API_KEY</code> + <code>ELEVENLABS_API_KEY</code> in <code>apps/web/.env</code> to generate real audio.
    </div>
  )}

  <script is:inline id="chapter-data" type="application/json" set:html={JSON.stringify(chapter)} />

  <section class="player">
    <audio id="audio" preload="metadata" src={chapter.audioSrc}></audio>

    <ol class="sentences" id="sentences">
      {chapter.sentences.map((s) => (
        <li
          class="sentence"
          data-idx={s.idx}
          data-start={s.start}
          data-end={s.end}
        >
          <div class="row">
            <span class="zh">{s.zh}</span>
            <button class="vault-btn" type="button" data-idx={s.idx} aria-label="Save to vault">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M5 4h14v16l-7-4-7 4z" />
              </svg>
              Vault
            </button>
          </div>
          <div class="pinyin">{s.pinyin}</div>
          <div class="en">{s.en}</div>
        </li>
      ))}
    </ol>
  </section>

  <div class="transport" role="region" aria-label="Audio transport">
    <button class="play-btn" id="play-btn" type="button" aria-label="Play">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" id="play-icon"><path d="M8 5v14l11-7z" /></svg>
    </button>
    <div class="progress-wrap">
      <div class="progress" id="progress"><div class="progress-fill" id="progress-fill"></div></div>
      <div class="time"><span id="time-current">0:00</span> / <span id="time-total">0:00</span></div>
    </div>
    <button class="mic-btn" id="mic-btn" type="button" disabled aria-label="Voice check-in (coming soon)">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M12 14a3 3 0 0 0 3-3V6a3 3 0 0 0-6 0v5a3 3 0 0 0 3 3zM5 11a7 7 0 0 0 14 0M12 18v3M8 21h8" />
      </svg>
    </button>
  </div>

  <div class="checkin" id="checkin" hidden aria-live="polite" role="dialog">
    <div class="checkin-inner">
      <span class="eyebrow">Comprehension check</span>
      <p class="q" id="checkin-question">…</p>
      <div class="transcript-wrap" id="transcript-wrap" hidden>
        <span class="transcript-label">You said:</span>
        <p class="transcript" id="checkin-transcript"></p>
      </div>
      <div class="feedback-wrap" id="feedback-wrap" hidden>
        <span class="score" id="checkin-score"></span>
        <p class="feedback" id="checkin-feedback"></p>
      </div>
      <div class="checkin-actions">
        <button class="big-mic" id="checkin-mic" type="button" aria-label="Speak your answer">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 14a3 3 0 0 0 3-3V6a3 3 0 0 0-6 0v5a3 3 0 0 0 3 3zM5 11a7 7 0 0 0 14 0M12 18v3M8 21h8" />
          </svg>
          <span id="mic-label">Hold to answer</span>
        </button>
        <button class="link-btn" id="checkin-skip" type="button">Skip · resume</button>
      </div>
    </div>
  </div>

  <div class="culture-card" id="culture-card" hidden aria-live="polite" role="dialog">
    <header>
      <span class="eyebrow">Cultural note</span>
      <button class="close" id="culture-close" type="button" aria-label="Dismiss">✕</button>
    </header>
    <h3 id="culture-term"></h3>
    <p class="literal"><b>Literal:</b> <span id="culture-literal"></span></p>
    <p class="meaning"><b>Meaning:</b> <span id="culture-meaning"></span></p>
    <p class="origin" id="culture-origin"></p>
    <button class="btn btn-primary" id="culture-resume" type="button">Resume</button>
  </div>
</AppShell>

<script>
  import { findSentenceAt } from "../../lib/chapter";
  import type { Chapter } from "../../lib/chapter";
  import { saveCard } from "../../lib/vault";
  import { getAnswerLang, getCheckinCadence } from "../../lib/settings";

  const dataEl = document.getElementById("chapter-data");
  if (!dataEl) throw new Error("missing chapter data");
  const chapter: Chapter = JSON.parse(dataEl.textContent ?? "{}");

  const audio = document.getElementById("audio") as HTMLAudioElement;
  const playBtn = document.getElementById("play-btn") as HTMLButtonElement;
  const playIcon = document.getElementById("play-icon")!;
  const progress = document.getElementById("progress")!;
  const fill = document.getElementById("progress-fill")!;
  const timeCur = document.getElementById("time-current")!;
  const timeTotal = document.getElementById("time-total")!;
  const sentencesEl = document.getElementById("sentences")!;
  const togglePinyin = document.getElementById("toggle-pinyin") as HTMLButtonElement;

  const cultureCard = document.getElementById("culture-card") as HTMLElement;
  const cultureTerm = document.getElementById("culture-term")!;
  const cultureLiteral = document.getElementById("culture-literal")!;
  const cultureMeaning = document.getElementById("culture-meaning")!;
  const cultureOrigin = document.getElementById("culture-origin")!;
  const cultureClose = document.getElementById("culture-close")!;
  const cultureResume = document.getElementById("culture-resume")!;

  // ─── transport ───────────────────────────────────────────────────────────
  function fmt(t: number) {
    if (!isFinite(t)) return "0:00";
    const m = Math.floor(t / 60);
    const s = Math.floor(t % 60);
    return `${m}:${s.toString().padStart(2, "0")}`;
  }

  audio.addEventListener("loadedmetadata", () => {
    timeTotal.textContent = fmt(audio.duration || chapter.durationSeconds);
  });
  timeTotal.textContent = fmt(chapter.durationSeconds);

  playBtn.addEventListener("click", () => {
    if (audio.paused) {
      audio.play().catch((e) => console.warn("[player] play failed:", e));
    } else {
      audio.pause();
    }
  });
  audio.addEventListener("play", () => {
    playIcon.innerHTML = '<rect x="6" y="5" width="4" height="14"/><rect x="14" y="5" width="4" height="14"/>';
    playBtn.setAttribute("aria-label", "Pause");
  });
  audio.addEventListener("pause", () => {
    playIcon.innerHTML = '<path d="M8 5v14l11-7z" />';
    playBtn.setAttribute("aria-label", "Play");
  });

  progress.addEventListener("click", (e) => {
    const rect = progress.getBoundingClientRect();
    const ratio = (e.clientX - rect.left) / rect.width;
    const dur = audio.duration || chapter.durationSeconds;
    audio.currentTime = Math.max(0, Math.min(dur, ratio * dur));
  });

  // ─── highlight + idiom watcher ───────────────────────────────────────────
  const firedIdioms = new Set<number>();
  let activeIdx = -1;

  audio.addEventListener("timeupdate", () => {
    const t = audio.currentTime;
    const dur = audio.duration || chapter.durationSeconds;
    fill.style.width = `${Math.min(100, (t / dur) * 100)}%`;
    timeCur.textContent = fmt(t);

    const s = findSentenceAt(chapter.sentences, t);
    const newIdx = s?.idx ?? -1;
    if (newIdx !== activeIdx) {
      sentencesEl.querySelector(".sentence.active")?.classList.remove("active");
      if (newIdx >= 0) {
        const el = sentencesEl.querySelector<HTMLElement>(`.sentence[data-idx="${newIdx}"]`);
        el?.classList.add("active");
        el?.scrollIntoView({ behavior: "smooth", block: "center" });
      }
      activeIdx = newIdx;
    }

    if (s) {
      const idiom = chapter.idioms.find((i) => i.sentenceIdx === s.idx);
      if (idiom && !firedIdioms.has(s.idx)) {
        firedIdioms.add(s.idx);
        openCultureCard(idiom);
      }
    }
  });

  // ─── pinyin toggle ───────────────────────────────────────────────────────
  let pinyinOn = true;
  togglePinyin.addEventListener("click", () => {
    pinyinOn = !pinyinOn;
    document.body.classList.toggle("pinyin-hidden", !pinyinOn);
    togglePinyin.textContent = `Pinyin: ${pinyinOn ? "on" : "off"}`;
    togglePinyin.setAttribute("aria-pressed", String(pinyinOn));
  });

  // ─── sentence click to seek ──────────────────────────────────────────────
  sentencesEl.addEventListener("click", (e) => {
    const target = e.target as HTMLElement;
    if (target.closest(".vault-btn")) return;
    const li = target.closest<HTMLElement>(".sentence");
    if (!li) return;
    const start = Number(li.dataset.start);
    audio.currentTime = start;
    if (audio.paused) audio.play().catch(() => {});
  });

  // ─── vault button ────────────────────────────────────────────────────────
  sentencesEl.addEventListener("click", async (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>(".vault-btn");
    if (!btn) return;
    e.stopPropagation();
    const idx = Number(btn.dataset.idx);
    const s = chapter.sentences[idx];
    if (!s) return;
    await saveCard({
      chapterId: chapter.chapterId,
      sentenceIdx: s.idx,
      zh: s.zh,
      pinyin: s.pinyin,
      en: s.en,
      audioSrc: chapter.audioSrc,
      start: s.start,
      end: s.end,
    });
    btn.classList.add("saved");
    btn.textContent = "Saved";
    setTimeout(() => {
      btn.classList.remove("saved");
      btn.innerHTML = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 4h14v16l-7-4-7 4z" /></svg> Vault`;
    }, 1400);
  });

  // ─── culture card ────────────────────────────────────────────────────────
  let wasPlayingBeforeCard = false;
  function openCultureCard(idiom: { term: string; literal: string; meaning: string; origin: string }) {
    wasPlayingBeforeCard = !audio.paused;
    audio.pause();
    cultureTerm.textContent = idiom.term;
    cultureLiteral.textContent = idiom.literal;
    cultureMeaning.textContent = idiom.meaning;
    cultureOrigin.textContent = idiom.origin;
    cultureCard.hidden = false;
    requestAnimationFrame(() => cultureCard.classList.add("open"));
  }
  function closeCultureCard(resume: boolean) {
    cultureCard.classList.remove("open");
    setTimeout(() => {
      cultureCard.hidden = true;
    }, 280);
    if (resume && wasPlayingBeforeCard) audio.play().catch(() => {});
  }
  cultureClose.addEventListener("click", () => closeCultureCard(false));
  cultureResume.addEventListener("click", () => closeCultureCard(true));

  // ─── voice check-ins ─────────────────────────────────────────────────────
  const checkinEl = document.getElementById("checkin") as HTMLElement;
  const qEl = document.getElementById("checkin-question")!;
  const transcriptWrap = document.getElementById("transcript-wrap")!;
  const transcriptEl = document.getElementById("checkin-transcript")!;
  const feedbackWrap = document.getElementById("feedback-wrap")!;
  const scoreEl = document.getElementById("checkin-score")!;
  const feedbackEl = document.getElementById("checkin-feedback")!;
  const micBtn = document.getElementById("checkin-mic") as HTMLButtonElement;
  const micLabel = document.getElementById("mic-label")!;
  const skipBtn = document.getElementById("checkin-skip") as HTMLButtonElement;
  const transportMicBtn = document.getElementById("mic-btn") as HTMLButtonElement;

  const firedCheckins = new Set<number>();
  let checkinOpen = false;
  let wasPlayingBeforeCheckin = false;
  let currentQuestion = "";
  let currentUptoIdx = 0;
  let currentLang: "en" | "zh" = "en";

  type SR = any;
  const SRCtor: { new (): SR } | undefined =
    (window as any).SpeechRecognition || (window as any).webkitSpeechRecognition;
  let recognition: SR | null = null;
  if (!SRCtor) {
    micBtn.disabled = true;
    micLabel.textContent = "STT unavailable";
  }

  function openCheckin() {
    checkinOpen = true;
    wasPlayingBeforeCheckin = !audio.paused;
    audio.pause();
    transcriptWrap.hidden = true;
    feedbackWrap.hidden = true;
    qEl.textContent = "Thinking of a question…";
    checkinEl.hidden = false;
    requestAnimationFrame(() => checkinEl.classList.add("open"));
  }

  function closeCheckin(resume: boolean) {
    checkinEl.classList.remove("open");
    setTimeout(() => {
      checkinEl.hidden = true;
    }, 280);
    checkinOpen = false;
    if (recognition) {
      try { recognition.abort(); } catch {}
    }
    if (resume && wasPlayingBeforeCheckin) audio.play().catch(() => {});
  }

  skipBtn.addEventListener("click", () => closeCheckin(true));

  async function speakViaServer(text: string, lang: "en" | "zh"): Promise<void> {
    try {
      const res = await fetch("/api/speak", {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify({ text, lang }),
      });
      if (!res.ok) {
        console.warn("[speak] server failed:", await res.text());
        // fallback: browser SpeechSynthesis
        return new Promise((r) => {
          const u = new SpeechSynthesisUtterance(text);
          u.lang = lang === "zh" ? "zh-CN" : "en-US";
          u.onend = () => r();
          u.onerror = () => r();
          window.speechSynthesis.speak(u);
        });
      }
      const blob = await res.blob();
      const url = URL.createObjectURL(blob);
      const a = new Audio(url);
      await a.play();
      return new Promise((r) => {
        a.onended = () => {
          URL.revokeObjectURL(url);
          r();
        };
      });
    } catch (e) {
      console.warn("[speak] failed:", e);
    }
  }

  async function fireCheckin(uptoIdx: number) {
    if (checkinOpen) return;
    currentUptoIdx = uptoIdx;
    currentLang = getAnswerLang();
    openCheckin();
    try {
      const res = await fetch("/api/checkin", {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify({
          chapterId: chapter.chapterId,
          uptoSentenceIdx: uptoIdx,
          answerLang: currentLang,
        }),
      });
      if (!res.ok) {
        qEl.textContent = "Couldn't reach the tutor. Skipping for now.";
        setTimeout(() => closeCheckin(true), 1600);
        return;
      }
      const { question } = await res.json();
      currentQuestion = question;
      qEl.textContent = question;
      await speakViaServer(question, currentLang);
    } catch (e) {
      console.warn("[checkin] failed:", e);
      qEl.textContent = "Offline — skipping check-in.";
      setTimeout(() => closeCheckin(true), 1600);
    }
  }

  // Hold-to-speak on mic
  let listening = false;
  let finalTranscript = "";
  function startListening() {
    if (!SRCtor || listening) return;
    finalTranscript = "";
    transcriptWrap.hidden = false;
    transcriptEl.textContent = "";
    recognition = new SRCtor();
    recognition.lang = currentLang === "zh" ? "zh-CN" : "en-US";
    recognition.interimResults = true;
    recognition.continuous = false;
    recognition.onresult = (event: any) => {
      let interim = "";
      for (let i = event.resultIndex; i < event.results.length; i++) {
        const r = event.results[i];
        if (r.isFinal) finalTranscript += r[0].transcript;
        else interim += r[0].transcript;
      }
      transcriptEl.textContent = finalTranscript + interim;
    };
    recognition.onerror = (e: any) => console.warn("[stt] error:", e.error);
    recognition.onend = () => {
      listening = false;
      micLabel.textContent = "Hold to answer";
      micBtn.classList.remove("listening");
      if (finalTranscript.trim()) gradeAnswer(finalTranscript.trim());
    };
    recognition.start();
    listening = true;
    micLabel.textContent = "Listening…";
    micBtn.classList.add("listening");
  }
  function stopListening() {
    if (recognition && listening) {
      try { recognition.stop(); } catch {}
    }
  }

  micBtn.addEventListener("pointerdown", (e) => {
    e.preventDefault();
    startListening();
  });
  micBtn.addEventListener("pointerup", stopListening);
  micBtn.addEventListener("pointerleave", stopListening);
  micBtn.addEventListener("pointercancel", stopListening);

  async function gradeAnswer(answer: string) {
    feedbackWrap.hidden = false;
    scoreEl.textContent = "scoring…";
    feedbackEl.textContent = "";
    try {
      const res = await fetch("/api/grade", {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify({
          chapterId: chapter.chapterId,
          uptoSentenceIdx: currentUptoIdx,
          question: currentQuestion,
          answer,
          answerLang: currentLang,
        }),
      });
      if (!res.ok) throw new Error(await res.text());
      const data = await res.json();
      scoreEl.textContent = data.score ?? "";
      scoreEl.dataset.score = data.score ?? "";
      feedbackEl.textContent = data.feedback ?? "";
      await speakViaServer(data.feedback, currentLang);
      setTimeout(() => closeCheckin(true), 600);
    } catch (e) {
      console.warn("[grade] failed:", e);
      scoreEl.textContent = "";
      feedbackEl.textContent = "Couldn't reach the tutor for grading. Resuming.";
      setTimeout(() => closeCheckin(true), 1400);
    }
  }

  // Trigger every Nth sentence
  audio.addEventListener("timeupdate", () => {
    if (checkinOpen) return;
    const s = findSentenceAt(chapter.sentences, audio.currentTime);
    if (!s) return;
    const cadence = getCheckinCadence();
    if (s.idx > 0 && (s.idx + 1) % cadence === 0 && !firedCheckins.has(s.idx)) {
      firedCheckins.add(s.idx);
      fireCheckin(s.idx);
    }
  });

  // Allow manual trigger from the transport mic button
  if (transportMicBtn) {
    transportMicBtn.disabled = false;
    transportMicBtn.removeAttribute("aria-disabled");
    transportMicBtn.setAttribute("aria-label", "Trigger a comprehension check now");
    transportMicBtn.addEventListener("click", () => {
      const s = findSentenceAt(chapter.sentences, audio.currentTime) ?? chapter.sentences[0];
      if (s) fireCheckin(s.idx);
    });
  }
</script>

<style>
  .stub-banner {
    border: 1px dashed color-mix(in oklab, var(--accent) 60%, var(--rule));
    background: color-mix(in oklab, var(--accent) 8%, var(--bg-elev));
    color: var(--ink);
    padding: 10px 14px;
    border-radius: 10px;
    font-size: 0.85rem;
    margin-bottom: 18px;
  }
  .stub-banner code {
    background: color-mix(in oklab, var(--accent) 14%, var(--bg-elev));
    padding: 1px 6px;
    border-radius: 4px;
    font-size: 0.78rem;
  }

  .player {
    max-width: 720px;
    margin: 0 auto;
  }

  .sentences {
    list-style: none;
    padding: 0;
    margin: 0 0 120px;
    display: grid;
    gap: 14px;
  }

  .sentence {
    padding: 18px 20px;
    border: 1px solid var(--rule);
    border-radius: 14px;
    background: var(--bg-elev);
    transition: border-color 200ms ease, background 200ms ease, transform 200ms ease;
    cursor: pointer;
  }
  .sentence:hover {
    border-color: color-mix(in oklab, var(--accent) 40%, var(--rule));
  }
  .sentence.active {
    border-color: var(--accent);
    background: color-mix(in oklab, var(--accent) 10%, var(--bg-elev));
    transform: translateY(-1px);
    box-shadow: var(--shadow);
  }

  .row {
    display: flex;
    align-items: start;
    justify-content: space-between;
    gap: 12px;
  }
  .zh {
    font-family: var(--font-serif);
    font-size: 1.35rem;
    line-height: 1.5;
    letter-spacing: 0.02em;
  }
  .pinyin {
    margin-top: 4px;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--ink-muted);
    letter-spacing: 0.01em;
  }
  body.pinyin-hidden .pinyin {
    display: none;
  }
  .en {
    margin-top: 6px;
    color: var(--ink-muted);
    font-size: 0.94rem;
  }

  .vault-btn {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    border: 1px solid var(--rule);
    background: var(--bg);
    border-radius: 999px;
    padding: 4px 10px 4px 8px;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--ink-muted);
    cursor: pointer;
    transition: background 140ms ease, color 140ms ease, border-color 140ms ease;
  }
  .vault-btn:hover {
    color: var(--accent);
    border-color: var(--accent);
  }
  .vault-btn.saved {
    background: var(--accent);
    color: var(--accent-ink);
    border-color: var(--accent);
  }

  .transport {
    position: fixed;
    left: 50%;
    bottom: calc(env(safe-area-inset-bottom) + 16px);
    transform: translateX(-50%);
    width: min(640px, calc(100% - 32px));
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 14px;
    padding: 10px 14px;
    border: 1px solid var(--rule);
    border-radius: 999px;
    background: color-mix(in oklab, var(--bg-elev) 92%, transparent);
    backdrop-filter: saturate(180%) blur(14px);
    box-shadow: var(--shadow);
    z-index: 30;
  }
  @media (max-width: 760px) {
    .transport {
      bottom: calc(env(safe-area-inset-bottom) + 72px);
    }
  }

  .play-btn, .mic-btn {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 0;
    display: grid;
    place-items: center;
    cursor: pointer;
  }
  .play-btn {
    background: var(--accent);
    color: var(--accent-ink);
  }
  .mic-btn {
    background: var(--bg);
    color: var(--ink-muted);
    border: 1px solid var(--rule);
  }
  .mic-btn[disabled] {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .progress-wrap {
    display: grid;
    gap: 4px;
  }
  .progress {
    height: 6px;
    background: color-mix(in oklab, var(--ink) 8%, transparent);
    border-radius: 999px;
    cursor: pointer;
    overflow: hidden;
  }
  .progress-fill {
    height: 100%;
    width: 0;
    background: var(--accent);
    transition: width 140ms linear;
  }
  .time {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--ink-muted);
    display: flex;
    justify-content: space-between;
  }

  .culture-card {
    position: fixed;
    left: 50%;
    bottom: 0;
    transform: translate(-50%, 100%);
    width: min(560px, calc(100% - 24px));
    background: var(--bg-elev);
    border: 1px solid var(--rule);
    border-bottom: 0;
    border-radius: 18px 18px 0 0;
    padding: 22px 22px calc(28px + env(safe-area-inset-bottom));
    box-shadow: 0 -20px 60px rgba(0,0,0,0.18);
    transition: transform 280ms cubic-bezier(.2,.7,.2,1);
    z-index: 40;
  }
  .culture-card.open {
    transform: translate(-50%, 0);
  }
  .culture-card header {
    display: flex;
