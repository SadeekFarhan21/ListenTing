---
import AppShell from "../../layouts/AppShell.astro";

const tiles = [
  {
    label: "Start listening",
    body: "Chapter 1 of 孙子兵法 — voice check-ins and cultural notes built in.",
    href: "/app/listen",
    accent: true,
  },
  {
    label: "Vocab Vault",
    body: "Review the words and phrases you've saved.",
    href: "/app/vault",
  },
  {
    label: "Settings",
    body: "Answer language, check-in cadence, theme.",
    href: "/app/settings",
  },
];

const activity = [
  { when: "What", what: "Voice-driven Mandarin audiobook learning, mobile-first." },
  { when: "Tap", what: "Tap a sentence to seek; tap the bookmark to save to your Vault." },
  { when: "Wait", what: "Every few sentences a tutor will pause and ask you a question." },
];
---

<AppShell title="Home · Hackathon" active="home">
  <span slot="title">Home</span>
  <div slot="actions">
    <a class="btn btn-primary" href="/app/listen">Start listening</a>
  </div>

  <section class="hero-card">
    <span class="eyebrow">Listen · learn · retain</span>
    <h2>An audiobook that listens back.</h2>
    <p>
      Press play on a classical Chinese text and a Claude-powered tutor will check
      your comprehension, surface cultural context, and let you bank vocabulary as
      you go — entirely by voice.
    </p>
  </section>

  <h3 class="section-h">Quick actions</h3>
  <ul class="tile-grid">
    {tiles.map((t) => (
      <li>
        <a href={t.href} class:list={["tile", { accent: t.accent }]}>
          <span class="tile-label">{t.label}</span>
          <span class="tile-body">{t.body}</span>
          <span class="tile-arrow" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M5 12h14M13 5l7 7-7 7" /></svg>
          </span>
        </a>
      </li>
    ))}
  </ul>

  <h3 class="section-h">Recent activity</h3>
  <ol class="activity">
    {activity.map((a) => (
      <li>
        <span class="when">{a.when}</span>
        <span class="what">{a.what}</span>
      </li>
    ))}
  </ol>
</AppShell>

<style>
  .hero-card {
    background:
      radial-gradient(80% 120% at 0% 0%, color-mix(in oklab, var(--accent) 22%, transparent), transparent 60%),
      var(--bg-elev);
    border: 1px solid var(--rule);
    border-radius: calc(var(--radius) + 4px);
    padding: clamp(22px, 4vw, 36px);
    margin-bottom: 28px;
    box-shadow: var(--shadow);
  }
  .hero-card h2 {
    margin-top: 6px;
    font-family: var(--font-serif);
    font-size: clamp(1.6rem, 3vw, 2.2rem);
  }
  .hero-card p {
    margin: 0;
    max-width: 56ch;
  }

  .section-h {
    margin: 22px 0 12px;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }

  .tile-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 12px;
  }
  .tile {
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-rows: auto auto;
    gap: 4px 12px;
    padding: 16px 18px;
    border: 1px solid var(--rule);
    border-radius: var(--radius);
    background: var(--bg-elev);
    transition: transform 140ms ease, border-color 140ms ease;
  }
  .tile:hover {
    transform: translateY(-1px);
    border-color: color-mix(in oklab, var(--accent) 50%, var(--rule));
  }
  .tile.accent {
    background:
      linear-gradient(180deg, color-mix(in oklab, var(--accent) 14%, var(--bg-elev)), var(--bg-elev));
    border-color: color-mix(in oklab, var(--accent) 35%, var(--rule));
  }
  .tile-label {
    font-weight: 600;
  }
  .tile-body {
    color: var(--ink-muted);
    font-size: 0.92rem;
    grid-column: 1;
  }
  .tile-arrow {
    grid-row: 1 / span 2;
    align-self: center;
    color: var(--accent);
  }

  .activity {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 4px;
    border: 1px solid var(--rule);
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--bg-elev);
  }
  .activity li {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: 16px;
    padding: 12px 16px;
    border-bottom: 1px solid var(--rule);
    font-size: 0.95rem;
  }
  .activity li:last-child {
    border-bottom: 0;
  }
  .when {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--ink-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding-top: 2px;
  }
</style>
