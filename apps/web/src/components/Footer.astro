---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container row">
    <p class="meta">
      <span class="dot" aria-hidden="true"></span>
      Built for the Anthropic Hackathon · {year}
    </p>
    <p class="links">
      <a href="https://github.com/SadeekFarhan21/Anthropic-Hackathon">GitHub</a>
      <span aria-hidden="true">·</span>
      <a href="#about">About</a>
    </p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--rule);
    padding-block: 24px;
    margin-top: 64px;
  }

  .row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }

  .meta {
    margin: 0;
    color: var(--ink-muted);
    font-family: var(--font-mono);
    font-size: 0.82rem;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .dot {
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: var(--accent);
  }

  .links {
    margin: 0;
    display: inline-flex;
    gap: 10px;
    color: var(--ink-muted);
    font-size: 0.9rem;
  }

  .links a:hover {
    color: var(--ink);
  }
</style>
