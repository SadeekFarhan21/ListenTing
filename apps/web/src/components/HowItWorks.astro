---
const steps = [
  {
    n: "01",
    title: "Add a page",
    body: "Drop a .astro file into src/pages — file-based routing handles the rest.",
    code: "src/pages/dashboard.astro",
  },
  {
    n: "02",
    title: "Reuse the layout",
    body: "Wrap content in <Base> for header, footer, fonts, and meta tags.",
    code: "<Base title=\"Dashboard\">…</Base>",
  },
  {
    n: "03",
    title: "Ship it",
    body: "pnpm build emits a static site you can host anywhere — no servers required.",
    code: "pnpm build && pnpm preview",
  },
];
---

<section id="how" class="how">
  <div class="container">
    <span class="eyebrow">How it works</span>
    <h2>From idea to deploy in three moves.</h2>

    <ol class="steps">
      {steps.map((s) => (
        <li class="step">
          <span class="n">{s.n}</span>
          <div>
            <h3>{s.title}</h3>
            <p>{s.body}</p>
            <pre><code>{s.code}</code></pre>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .how {
    padding-block: clamp(48px, 8vh, 88px);
  }

  .steps {
    list-style: none;
    padding: 0;
    margin: 32px 0 0;
    display: grid;
    gap: 16px;
  }

  .step {
    display: grid;
    grid-template-columns: 64px 1fr;
    gap: 18px;
    padding: 22px;
    border: 1px solid var(--rule);
    border-radius: var(--radius);
    background: var(--bg-elev);
  }

  .n {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--accent);
    letter-spacing: 0.08em;
    padding-top: 6px;
  }

  .step h3 {
    margin-bottom: 4px;
  }

  pre {
    margin: 10px 0 0;
    background: color-mix(in oklab, var(--accent) 8%, transparent);
    border: 1px solid var(--rule);
    border-radius: 10px;
    padding: 10px 12px;
    overflow-x: auto;
    font-size: 0.88rem;
    color: var(--ink);
  }
</style>
