---
// Lightweight install affordance.
// Hidden by default — appears only when the browser fires `beforeinstallprompt`,
// or when running on iOS Safari (where the prompt is manual).
---

<aside id="install-prompt" class="install-prompt" hidden>
  <div class="dot" aria-hidden="true"></div>
  <div class="copy">
    <strong>Install this site as an app</strong>
    <span id="install-hint">Faster launches, offline support, and a home-screen icon.</span>
  </div>
  <div class="cta">
    <button class="btn btn-primary" type="button" id="install-go" hidden>Install</button>
    <button class="btn btn-ghost" type="button" id="install-dismiss" aria-label="Dismiss">Not now</button>
  </div>
</aside>

<script>
  const root = document.getElementById("install-prompt");
  const go = document.getElementById("install-go") as HTMLButtonElement | null;
  const dismiss = document.getElementById("install-dismiss");
  const hint = document.getElementById("install-hint");
  let deferred: any = null;

  if (localStorage.getItem("install-dismissed") === "1") {
    // user already said no — respect it
  } else {
    const standalone =
      window.matchMedia("(display-mode: standalone)").matches ||
      (navigator as any).standalone === true;

    const isIOS = /iphone|ipad|ipod/i.test(navigator.userAgent);

    if (standalone) {
      // already installed — nothing to do
    } else if (isIOS) {
      // iOS doesn't fire beforeinstallprompt; surface manual instructions instead.
      hint!.textContent = "On iOS: tap Share, then 'Add to Home Screen'.";
      go!.hidden = true;
      root!.hidden = false;
    }
  }

  window.addEventListener("beforeinstallprompt", (e: Event) => {
    if (localStorage.getItem("install-dismissed") === "1") return;
    e.preventDefault();
    deferred = e;
    go!.hidden = false;
    root!.hidden = false;
  });

  go?.addEventListener("click", async () => {
    if (!deferred) return;
    deferred.prompt();
    await deferred.userChoice;
    deferred = null;
    root!.hidden = true;
  });

  dismiss?.addEventListener("click", () => {
    localStorage.setItem("install-dismissed", "1");
    root!.hidden = true;
  });

  window.addEventListener("appinstalled", () => {
    root!.hidden = true;
  });
</script>

<style>
  .install-prompt {
    position: fixed;
    left: 50%;
    bottom: calc(env(safe-area-inset-bottom) + 16px);
    transform: translateX(-50%);
    z-index: 60;
    display: inline-flex;
    align-items: center;
    gap: 14px;
    padding: 12px 14px 12px 16px;
    border: 1px solid var(--rule);
    border-radius: 999px;
    background: color-mix(in oklab, var(--bg-elev) 96%, transparent);
    backdrop-filter: saturate(180%) blur(14px);
    box-shadow: var(--shadow);
    max-width: calc(100vw - 24px);
  }
  .dot {
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: var(--accent);
    box-shadow: 0 0 0 4px color-mix(in oklab, var(--accent) 18%, transparent);
  }
  .copy {
    display: grid;
    line-height: 1.3;
    font-size: 0.88rem;
    color: var(--ink-muted);
  }
  .copy strong {
    color: var(--ink);
    font-weight: 600;
    font-size: 0.92rem;
  }
  .cta {
    display: inline-flex;
    gap: 6px;
  }
  .cta .btn {
    height: 34px;
    padding-inline: 12px;
    font-size: 0.85rem;
  }

  @media (max-width: 540px) {
    .install-prompt {
      border-radius: 14px;
      flex-direction: column;
      align-items: stretch;
      text-align: left;
      left: 12px;
      right: 12px;
      transform: none;
      max-width: none;
    }
    .cta {
      justify-content: flex-end;
    }
  }
</style>
