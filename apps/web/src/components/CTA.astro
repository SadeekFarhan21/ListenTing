---
---

<section id="get-started" class="cta-section">
  <div class="container card">
    <div>
      <span class="eyebrow">Ready when you are</span>
      <h2>Clone, install, and start shipping.</h2>
      <p>Three commands to get the team on the same page.</p>
    </div>
    <pre><code>{`pnpm install
pnpm dev
open http://localhost:4321`}</code></pre>
  </div>
</section>

<style>
  .cta-section {
    padding-block: clamp(40px, 7vh, 80px);
  }

  .card {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 32px;
    align-items: center;
    padding: clamp(28px, 4vw, 48px);
    border-radius: calc(var(--radius) + 6px);
    background:
      radial-gradient(80% 120% at 0% 0%, color-mix(in oklab, var(--accent) 20%, transparent), transparent 60%),
      var(--bg-elev);
    border: 1px solid var(--rule);
    box-shadow: var(--shadow);
  }

  .card p {
    margin: 0;
  }

  pre {
    margin: 0;
    padding: 20px;
    background: #0f0d0a;
    color: #f4e9dc;
    border-radius: 12px;
    overflow-x: auto;
    font-size: 0.95rem;
    line-height: 1.6;
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.05);
  }

  @media (max-width: 760px) {
    .card {
      grid-template-columns: 1fr;
    }
  }
</style>
