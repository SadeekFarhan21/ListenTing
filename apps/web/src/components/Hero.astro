---
---

<section class="hero">
  <div class="container">
    <span class="eyebrow">Anthropic Hackathon · 2026</span>
    <h1>
      Build something
      <em>worth shipping</em>
      this weekend.
    </h1>
    <p class="lede">
      A clean, fast frontend scaffold for our hackathon project — typed,
      themed, and ready for the team to iterate on. Drop in routes,
      components, and an API as needed.
    </p>
    <div class="cta">
      <a class="btn btn-primary" href="/app">
        Launch app
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true">
          <path d="M5 12h14M13 5l7 7-7 7" />
        </svg>
      </a>
      <a class="btn btn-ghost" href="#features">Explore features</a>
    </div>

    <div class="stats" role="list">
      <div role="listitem">
        <span class="num">∞</span>
        <span class="label">Possible ideas</span>
      </div>
      <div role="listitem">
        <span class="num">48h</span>
        <span class="label">Build window</span>
      </div>
      <div role="listitem">
        <span class="num">1</span>
        <span class="label">Shipped product</span>
      </div>
    </div>
  </div>

  <div class="halo" aria-hidden="true"></div>
</section>

<style>
  .hero {
    position: relative;
    padding-block: clamp(64px, 12vh, 128px) clamp(48px, 9vh, 96px);
    overflow: hidden;
  }

  h1 em {
    font-style: italic;
    color: var(--accent);
  }

  .lede {
    max-width: 56ch;
    font-size: 1.15rem;
    color: var(--ink-muted);
  }

  .cta {
    display: inline-flex;
    gap: 12px;
    margin-top: 18px;
    flex-wrap: wrap;
  }

  .stats {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
    margin-top: 56px;
    max-width: 520px;
    padding-top: 28px;
    border-top: 1px solid var(--rule);
  }

  .stats > div {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .num {
    font-family: var(--font-serif);
    font-size: 1.8rem;
    color: var(--ink);
  }

  .label {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-muted);
  }

  .halo {
    position: absolute;
    pointer-events: none;
    inset: -20% -10% auto auto;
    width: 60vw;
    max-width: 720px;
    aspect-ratio: 1;
    background: radial-gradient(
      closest-side,
      color-mix(in oklab, var(--accent) 35%, transparent),
      transparent 70%
    );
    filter: blur(20px);
    opacity: 0.55;
    z-index: -1;
  }
</style>
