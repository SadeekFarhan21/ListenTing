---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import InstallPrompt from "../components/InstallPrompt.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Anthropic Hackathon",
  description = "A frontend built for the Anthropic Hackathon.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- PWA: makes the same frontend installable as a standalone app -->
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#f7f5f1" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#14110d" media="(prefers-color-scheme: dark)" />
    <meta name="application-name" content="Hackathon" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-title" content="Hackathon" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <link rel="apple-touch-icon" href="/icon.svg" />

    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <title>{title}</title>
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <InstallPrompt />

    <script is:inline>
      // Register the service worker so the site is installable + works offline.
      // Skipped on localhost-via-http only when SW is unsupported (Safari iOS < 11.3 etc.).
      if ("serviceWorker" in navigator) {
        window.addEventListener("load", () => {
          navigator.serviceWorker.register("/sw.js").catch(() => {
            /* registration failure is non-fatal */
          });
        });
      }
    </script>
  </body>
</html>
